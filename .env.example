# Database Configuration
# For Railway: Use the PostgreSQL database URL provided by Railway
DATABASE_URL=postgresql://user:password@host:5432/dbname

# LLM Configuration
# Using Groq (free tier available at https://console.groq.com)
BUILT_IN_FORGE_API_URL=https://api.groq.com/openai
BUILT_IN_FORGE_API_KEY=your_groq_api_key_here

# JWT Secret for session tokens
JWT_SECRET=your_random_secret_here

# OAuth (optional - currently bypassed with hardcoded user)
OAUTH_SERVER_URL=https://api.manus.im
VITE_APP_ID=your_app_id
VITE_OAUTH_PORTAL_URL=https://manus.im
OWNER_OPEN_ID=omni-boss

# Frontend Configuration
VITE_FRONTEND_FORGE_API_URL=https://api.groq.com/openai
VITE_FRONTEND_FORGE_API_KEY=your_groq_api_key_here

# Node Environment
NODE_ENV=production
PORT=3000
